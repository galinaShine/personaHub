{
  "manifest_version": 3,
  "name": "PersonaHub",
  "version": "1.1.0",
  "description": "Спросите мнение синтетической персоны или сохраните цитату в досье",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PersonaHub Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
